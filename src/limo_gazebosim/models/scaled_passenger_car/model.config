<?xml version='1.0' encoding='utf-8'?>
<model>
  <name>scaled_passenger_car</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>
  <author>
    <name>Nate Koenig</name>
    <email>nate@osrfoundation.org</email>
  </author>
  <depend>
    <model>
      <uri>model://hatchback</uri>
