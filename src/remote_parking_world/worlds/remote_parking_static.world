    <!-- ============================================================
         8. STATIC CARS (7대 — 실제 LIMO 메시 사용)
         모두 static=true, model://static_limo 참조
         Z = 0.145 (base_link 높이: 바퀴가 지면에 닿도록)
         Yaw:
           Row A (북쪽 슬롯): -π/2 (앞면이 차로 방향, -Y)
           Row B (남쪽 슬롯): +π/2 (앞면이 차로 방향, +Y)

         슬롯 배치:
           A3 = LIMO 2 동적 스폰 (spawn_robots.launch.py)
           나머지 7칸 (A1,A2,A4,B1,B2,B3,B4) = static_limo 모델
         ============================================================ -->

    <!-- ROW A -->
    <include>
      <uri>model://static_limo</uri>
      <name>static_car_a_minus1</name>
      <pose>-1.575 0.985 0.145 0 0 -1.5708</pose>
      <static>true</static>
    </include>
    <include>
      <uri>model://static_limo</uri>
      <name>static_car_a0</name>
      <pose>-1.125 0.985 0.145 0 0 -1.5708</pose>
      <static>true</static>
    </include>
    <include>
      <uri>model://static_limo</uri>
      <name>static_car_a1</name>
      <pose>-0.675 0.985 0.145 0 0 -1.5708</pose>
      <static>true</static>
    </include>



    <!-- A3 : LIMO 2 슬롯 — spawn_robots.launch.py 에서 동적 스폰 -->



    <include>
      <uri>model://static_limo</uri>
      <name>static_car_a5</name>
      <pose>1.125 0.985 0.145 0 0 -1.5708</pose>
      <static>true</static>
    </include>
    <include>
      <uri>model://static_limo</uri>
      <name>static_car_a6</name>
      <pose>1.575 0.985 0.145 0 0 -1.5708</pose>
      <static>true</static>
    </include>
    <!-- ROW B -->
    <include>
      <uri>model://static_limo</uri>
      <name>static_car_b_minus1</name>
      <pose>-1.575 -0.985 0.145 0 0 1.5708</pose>
      <static>true</static>
    </include>
    <include>
      <uri>model://static_limo</uri>
      <name>static_car_b0</name>
      <pose>-1.125 -0.985 0.145 0 0 1.5708</pose>
      <static>true</static>
    </include>
    <include>
      <uri>model://static_limo</uri>
      <name>static_car_b1</name>
      <pose>-0.675 -0.985 0.145 0 0 1.5708</pose>
