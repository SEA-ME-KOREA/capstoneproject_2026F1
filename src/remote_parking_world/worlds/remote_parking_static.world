    </include>

    <include>
      <uri>model://static_limo</uri>
      <name>static_car_b3</name>
      <pose>0.225 -0.985 0.145 0 0 1.5708</pose>
      <static>true</static>
    </include>

    <include>
      <uri>model://static_limo</uri>
      <name>static_car_b4</name>
